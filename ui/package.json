{
  "name": "yz-head-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Robot-head avatar UI — shipped as a react-dynamic-module IIFE for JarvYZ (dashboard variant 11), also buildable as a standalone SPA served by the satellite at /.",
  "scripts": {
    "dev": "vite",
    "build:lib": "vite build --mode lib",
    "build:pages": "vite build --mode pages",
    "install-to-frontend": "node scripts/install-to-frontend.mjs",
    "ship": "npm run build:lib && npm run install-to-frontend",
    "preview": "vite preview --port 5186"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  }
}
